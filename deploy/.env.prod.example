# Production env template (예시). 이 파일을 복사해 서버에서만 실제 값을 채운다.
# 저장소에 실제 secret/credential 을 커밋하지 않는다.
#
# 사용 예:
#   cp deploy/.env.prod.example deploy/.env.prod
#   # deploy/.env.prod 는 .gitignore 대상으로 서버에만 둔다
#   docker compose -f deploy/compose.prod.example.yml --env-file deploy/.env.prod pull
#   docker compose -f deploy/compose.prod.example.yml --env-file deploy/.env.prod up -d

# Docker Hub namespace (실제 계정명으로 교체). image: ${DOCKERHUB_USERNAME}/dasida-api|web
DOCKERHUB_USERNAME=your-dockerhub-username

# Docker Hub image tag — main 이 아닌 sha-* pin 권장 (rollback 단위)
DASIDA_IMAGE_TAG=sha-xxxxxxxx

# Web image build 시 bake-in 되는 값. 런타임 env 로는 변경되지 않음.
# main push 후 해당 sha 의 Web image 가 이 URL 로 빌드됐는지 확인한다.
NEXT_PUBLIC_API_URL=https://api.example.com

SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=replace-with-secret-minimum-32-bytes
DB_URL=jdbc:mysql://replace-with-db-host:3306/dasida?useSSL=true&serverTimezone=Asia/Seoul&characterEncoding=utf8
DB_USER=replace-with-user
DB_PASSWORD=replace-with-password
APP_CORS_ALLOWED_ORIGINS=https://example.com
SPRING_DATA_REDIS_HOST=replace-with-redis-host
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=replace-if-used
